# ---- Required ----
MONGO_URL=mongodb://localhost:27017
DB_NAME=audit_ai

# ---- Auth / Crypto (generate your own!) ----
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=60

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=REPLACE_WITH_44_CHAR_BASE64_FERNET_KEY

# ---- CORS ----
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# ---- LLM (optional — Claude Sonnet via Emergent Universal Key) ----
# Leave blank to run fully offline (Copilot will still work with heuristic fallbacks).
EMERGENT_LLM_KEY=

# ---- Redis (optional — falls back to Mongo-backed cache if unset or unreachable) ----
# REDIS_URL=redis://localhost:6379/0
